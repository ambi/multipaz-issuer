option_settings:
  aws:elasticbeanstalk:application:environment:
    PORT: "8080"
    BASE_URL: ""
    ENTRA_REDIRECT_URI: ""
    KEY_STORE_PATH: "issuer-keystore.p12"
    KEY_STORE_PASSWORD: "changeit"
    ISSUING_COUNTRY: "JP"
    ISSUING_AUTHORITY: "VDC Apps Issuer"
  # Sensitive values (ENTRA_TENANT_ID, ENTRA_CLIENT_ID, ENTRA_CLIENT_SECRET)
  # must be set via EB console or: eb setenv ENTRA_TENANT_ID=xxx ...
