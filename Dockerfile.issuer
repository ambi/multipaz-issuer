FROM eclipse-temurin:21-jdk-jammy AS builder
WORKDIR /workspace

# Copy Gradle wrapper and build config (dependency cache layer)
COPY gradlew .
COPY gradle/ gradle/
COPY gradle.properties .
COPY settings.gradle.kts .
COPY build.gradle.kts .
COPY issuer/build.gradle.kts issuer/build.gradle.kts
COPY verifier/build.gradle.kts verifier/build.gradle.kts

RUN ./gradlew :issuer:dependencies --no-daemon -q

# Copy source and build
COPY issuer/src issuer/src
RUN ./gradlew :issuer:installDist --no-daemon

# Runtime image
FROM eclipse-temurin:21-jre-jammy
WORKDIR /app

# 非 root ユーザーで実行
RUN groupadd --system appgroup && useradd --system --gid appgroup appuser

COPY --from=builder /workspace/issuer/build/install/issuer/ .

# キーストア保存用ディレクトリ
RUN mkdir -p /app/data && chown appuser:appgroup /app/data

USER appuser

EXPOSE 8080
ENV PORT=8080
ENV LOG_FORMAT=json

HEALTHCHECK --interval=30s --timeout=5s --start-period=15s --retries=3 \
    CMD curl -sf http://localhost:${PORT}/health || exit 1

CMD ["bin/issuer"]
